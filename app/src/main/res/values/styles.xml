<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Match the background color of your splash image -->
        <item name="windowSplashScreenBackground">#F8F9FF</item>
        <!-- Keep the icon transparent or very small as we will show the full image in Compose -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartVoiceManager</item>
    </style>
</resources>
